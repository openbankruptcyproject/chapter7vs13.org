<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Can student loans be discharged in bankruptcy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In limited cases, yes. You must prove \"undue hardship\" through an adversary proceeding. The 2022 DOJ guidance has made this easier for federal loans. Private student loans still require the traditional undue hardship showing."
      }
    },
    {
      "@type": "Question",
      "name": "Is Chapter 7 or Chapter 13 better for student loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Neither chapter automatically discharges student loans. However, Chapter 7 eliminates other debts in months, freeing income for student loan payments. Chapter 13 can include student loans in the plan but requires 3-5 years of payments."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Brunner test?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Brunner test requires proving three things: (1) you cannot maintain a minimal living standard while repaying, (2) your hardship will persist, and (3) you made good-faith repayment efforts. Some circuits use a more flexible totality-of-circumstances test."
      }
    },
    {
      "@type": "Question",
      "name": "How do I file an adversary proceeding for student loans?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An adversary proceeding is a lawsuit within your bankruptcy case. You file a complaint alleging undue hardship, serve it on the lender, and the court conducts a trial or hearing. An attorney experienced in student loan discharge is strongly recommended."
      }
    }
  ]
}
